# Mirakl Product Enrichment — environment template. Copy to .env.local (gitignored) and fill in.
# Nothing here is required just to run the demo UI; the Worker and Mirakl write-back read these.

# --- Mirakl dev-tenant write-back (ADR 0005 / 0007) ----------------------------------------------
# All write-back is hard-restricted to the dev tenant; production is unreachable with no override.
MIRAKL_BASE_URL=https://seidor-dev.mirakl.net
# Static operator API key (a UUID). Sent directly per MIRAKL_AUTH_SCHEME. Never source .credentials.txt.
MIRAKL_OPERATOR_API_KEY=
# Authorization header scheme: raw (default — static-key convention) or bearer (Mirakl Connect).
MIRAKL_AUTH_SCHEME=raw
# The shop + category the single-row import targets. Must be internally consistent: the category's
# real attribute codes (from data/mirakl/catalog-config/*) must match the shop authorized for it.
MIRAKL_SYNC_SHOP_ID=
MIRAKL_SYNC_CATEGORY_CODE=

# --- Research Worker timing (server/worker, optional — sensible defaults if unset) ---------------
# Worker poll interval for the QUEUED job queue (ms, default 2000).
RESEARCH_POLL_MS=2000
# Per-runner hard timeout for one CLI attempt (ms, default 300000 = 5 min).
RESEARCH_RUN_TIMEOUT_MS=300000
# How often the Worker re-checks runner CLI install/login availability (ms, default 300000).
RESEARCH_AVAILABILITY_REFRESH_MS=300000

# --- Demo presentation pacing --------------------------------------------------------------------
# Paces the branded import-progress animation only (the import itself is sub-second). Seconds.
NEXT_PUBLIC_MOCK_PRODUCT_IMPORT_SECONDS=5
