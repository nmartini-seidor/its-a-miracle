{
  "name": "mirakl-product-enrichment",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "DEMO_DB_ISOLATE=1 node --experimental-strip-types --experimental-specifier-resolution=node --test tests/*.test.mjs",
    "reset:demo": "node --experimental-strip-types -e \"import('./server/store.ts').then((m) => m.resetDemoState())\"",
    "import:demo": "node --experimental-strip-types -e \"import('./server/store.ts').then((m) => m.importDemoProducts())\"",
    "worker": "node --experimental-strip-types --experimental-specifier-resolution=node server/worker/main.ts",
    "sync:mirakl": "node scripts/sync-mirakl-snapshot.mjs",
    "import:snapshot": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/import-snapshot.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "latest",
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-dropdown-menu": "latest",
    "@radix-ui/react-label": "latest",
    "@radix-ui/react-popover": "latest",
    "@radix-ui/react-progress": "latest",
    "@radix-ui/react-scroll-area": "latest",
    "@radix-ui/react-separator": "latest",
    "@radix-ui/react-slot": "latest",
    "@radix-ui/react-tabs": "latest",
    "@radix-ui/react-tooltip": "latest",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "next-themes": "latest",
    "react": "latest",
    "react-dom": "latest",
    "sonner": "latest",
    "tailwind-merge": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/better-sqlite3": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "^9.39.1",
    "eslint-config-next": "latest",
    "tailwindcss": "latest",
    "tw-animate-css": "latest",
    "typescript": "latest"
  }
}
